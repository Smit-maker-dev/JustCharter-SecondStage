{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/about", "destination": "/about.html" },
    { "source": "/services", "destination": "/services.html" },
    { "source": "/fleet", "destination": "/fleet.html" },
    { "source": "/destinations", "destination": "/destinations.html" },
    { "source": "/members", "destination": "/members.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/planner", "destination": "/planner.html" },
    { "source": "/empty-legs", "destination": "/empty-legs.html" },
    { "source": "/safety-first", "destination": "/safety-first.html" },
    { "source": "/careers", "destination": "/careers.html" },
    { "source": "/corporate-accounts", "destination": "/corporate-accounts.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/cookie-policy", "destination": "/cookie-policy.html" },
    { "source": "/history", "destination": "/history.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
